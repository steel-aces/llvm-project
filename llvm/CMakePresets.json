{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "installDir": "${sourceDir}/out",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "LLVM_TARGETS_TO_BUILD": "WebAssembly",
        "BUILD_SHARED_LIBS": "OFF",
        "LLVM_ENABLE_PROJECTS": "clang;lld",
        "LLVM_ENABLE_TELEMETRY": "OFF",
        "LLVM_ENABLE_DIA_SDK": "OFF",
        "LLVM_ENABLE_UNWIND_TABLES": "OFF",
        "LLVM_ENABLE_BACKTRACES": "OFF",
        "LLVM_ENABLE_CRASH_OVERRIDES": "OFF",
        "LLVM_ENABLE_CRASH_DUMPS": "OFF",
        "LLVM_ENABLE_LIBXML2": "OFF",
        "LLVM_ENABLE_LIBEDIT": "OFF",
        "LLVM_ENABLE_LIBPFM": "OFF",
        "LLVM_ENABLE_THREADS": "OFF",
        "LLVM_ENABLE_ICU": "OFF",
        "LLVM_ENABLE_ZLIB": "OFF",
        "LLVM_ENABLE_ZSTD": "OFF",
        "LLVM_ENABLE_Z3_SOLVER": "OFF",
        "LLVM_ENABLE_OCAMLDOC": "OFF",
        "LLVM_ENABLE_BINDINGS": "OFF",
        "LLVM_ENABLE_PLUGINS": "OFF",
        "LLVM_INCLUDE_TOOLS": "ON",
        "LLVM_INCLUDE_UTILS": "OFF",
        "LLVM_INCLUDE_RUNTIMES": "OFF",
        "LLVM_INCLUDE_EXAMPLES": "OFF",
        "LLVM_INCLUDE_TESTS": "OFF",
        "LLVM_INCLUDE_BENCHMARKS": "OFF",
        "LLVM_INCLUDE_DOCS": "OFF",
        "LLVM_BUILD_TOOLS": "OFF",
        "LLVM_BUILD_UTILS": "OFF",
        "LLVM_BUILD_RUNTIME": "OFF",
        "LLVM_BUILD_RUNTIMES": "OFF",
        "LLVM_BUILD_EXAMPLES": "OFF",
        "LLVM_BUILD_TESTS": "OFF",
        "LLVM_BUILD_BENCHMARKS": "OFF",
        "LLVM_BUILD_LLVM_C_DYLIB": "OFF",
        "LLVM_BUILD_LLVM_DYLIB": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "targets": ["clang", "lld"]
    }
  ]
}
